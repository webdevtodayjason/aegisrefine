# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aegis

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Conductor — runs IN-PROCESS (Python + CLI + SQLite). There is NO HTTP endpoint.
# Point these at the real frontier-infra/conductor checkout + Hermes kanban DB.
CONDUCTOR_REPO_PATH=/path/to/conductor
HERMES_KANBAN_DB=/path/to/.hermes/kanban/boards/aegis/kanban.db

# Inference — Aegis-14B LIVE on Spark-1 via AInode (bf16; AWQ swaps in at the SAME url, no code change).
# Backend runs ON Spark-1 -> localhost. From other hosts -> Spark-1 tailnet 100.122.26.9.
AINODE_API_URL=http://localhost:8001/v1
AINODE_MODEL=Aegis-14B
AINODE_API_KEY=EMPTY

# Email — aegisrefine.com verified on Resend (Cloudflare DNS, us-east-1) 2026-06-27, ready to send
RESEND_API_KEY=re_...

# Security
SECRET_KEY=your-secret-key-here
ADMIN_API_KEY=change-me-before-demo
